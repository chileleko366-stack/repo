# LLM — script generation rotates through providers on rate-limit (first available wins)
GROQ_API_KEY=          # groq.com — llama-3.3-70b-versatile (free tier 12K TPM)
SAMBANOVA_API_KEY=     # sambanova.ai — Meta-Llama-3.3-70B-Instruct (free tier)
XAI_API_KEY=           # x.ai — grok-3-mini (free tier)
GEMINI_API_KEY=        # aistudio.google.com — gemini-2.0-flash (free tier)
ANTHROPIC_API_KEY=     # anthropic.com — reserved for future use

# Stock media (both required for fallback chain)
PEXELS_API_KEY=       # free at pexels.com/api
PIXABAY_API_KEY=      # free at pixabay.com/api/docs

# Space / Brain 3D (set to 1 to render live; default uses baked .webm)
SPACE_LIVE_3D=0
BRAIN_LIVE_3D=0

# Optional: higher-quality whoosh SFX
FREESOUND_API_KEY=

# Per-channel YouTube OAuth credentials.
# N is the 1-based alphabetical index of configs/channels/*.json
# (ch1.json -> 1, ch2.json -> 2, ... ch6.json -> 6).
# Consumed by src/scripts/upload_all.py and .github/workflows/nightly-pipeline.yml.
YT_CH1_CLIENT_ID=
YT_CH1_CLIENT_SECRET=
YT_CH1_REFRESH_TOKEN=
YT_CH2_CLIENT_ID=
YT_CH2_CLIENT_SECRET=
YT_CH2_REFRESH_TOKEN=
YT_CH3_CLIENT_ID=
YT_CH3_CLIENT_SECRET=
YT_CH3_REFRESH_TOKEN=
YT_CH4_CLIENT_ID=
YT_CH4_CLIENT_SECRET=
YT_CH4_REFRESH_TOKEN=
YT_CH5_CLIENT_ID=
YT_CH5_CLIENT_SECRET=
YT_CH5_REFRESH_TOKEN=
YT_CH6_CLIENT_ID=
YT_CH6_CLIENT_SECRET=
YT_CH6_REFRESH_TOKEN=
